; Engine configuration file.
; Proyecto de referencia del laboratorio "3D en tercera persona" del
; Programa de Desarrollo de Videojuegos Moderno.

config_version=5

[application]

config/name="3D Tercera Persona — Solución"
config/description="Solución de referencia del capstone de la Parte 2 (clase 067)."
run/main_scene="res://escenas/mundo.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")

[autoload]

GameState="*res://scripts/game_state.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720

