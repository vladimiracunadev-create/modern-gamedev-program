[layer_names]

2d_physics/layer_1="Mundo"
2d_physics/layer_2="Jugador"
2d_physics/layer_3="Enemigo"
2d_physics/layer_4="Recolectable"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
; Nearest: imprescindible para que el pixel art no salga borroso (clase 019).
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.42, 0.65, 0.9, 1)
