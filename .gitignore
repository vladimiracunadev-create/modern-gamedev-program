# === Entornos y dependencias ===
.venv/
venv/
env/
__pycache__/
*.py[cod]
node_modules/

# === Sitio generado para GitHub Pages (build artifact) ===
site/

# === Logs temporales de scripts/verificar_todo.py ===
.verif_red/

# === Godot 4 ===
# Carpeta de importación/caché del editor (se regenera sola).
.godot/
# Metadatos de importación de assets: los regenera `godot --import` (que es lo
# que hace la CI de labs, y lo que hace el editor al abrir el proyecto). No se
# versionan porque ningún asset de los labs usa ajustes de importación propios.
*.import
# Traducciones compiladas desde el CSV: mismo caso, las genera el import. Lo que
# se versiona y se edita es el .csv.
*.translation
# Exportaciones/builds del juego.
export.cfg
export_presets.cfg
build/
builds/
exports/
*.pck

